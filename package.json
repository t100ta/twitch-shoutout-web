{
  "name": "twitch-shoutout-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "serve:dev": "pnpm run build:dev && firebase emulators:start --only hosting",
