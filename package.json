    "typescript-eslint": "^8.15.0",
    "vite": "^6.3.4",
    "vite-tsconfig-paths": "^5.1.3",
    "vitest": "^4.0.18"
  },
  "volta": {
    "node": "24.13.1",
    "yarn": "4.5.3"
  },
