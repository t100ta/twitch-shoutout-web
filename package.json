    "firebase-admin": "^14.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.12.0",
    "tmi.js": "^1.8.5",
    "typescript-cookie": "^1.0.6",
    "zustand": "^5.0.2"
  },
