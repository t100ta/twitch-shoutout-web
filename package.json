    "axios": "^1.13.5",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.0.2",
    "tmi.js": "file:src/libs/tmi.js",
    "typescript-cookie": "^1.0.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^24.0.0",
